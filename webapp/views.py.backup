def addtocart_p(request):
    if "pemail" in request.session:
        pemail=request.session['pemail']
        pname=request.session['pname']
        did=request.GET['did']
        cnt=int(request.GET['count'])
        d=drug.objects.filter(did=did)
        d=d[0]
        cost=d.cost
        totcost=cost*cnt
        
        c1=drugstock_p.objects.filter(did=did).count()
        if c1>0:
            s1=cart_p(did=did, mname=d.drugname, totcost=totcost, count=cnt, pemail=pemail)
            s1.save()
            
        else:
            s1=drugstock_p(did=did, drugname=d.drugname, mname=d.mname, typ_e=d.typ_e, uses=d.uses, instructions=d.instructions, cost=d.cost, mrp=d.mrp, pname=pname, pemail=pemail, stock=0)
            s1.save()
            s1=cart_p(did=did, mname=d.mname, totcost=totcost, count=cnt, pemail=pemail)
            s1.save()
            
        
        d=drug.objects.filter(stock__gt=0)

        return render(request, 'pviewdrug.html',{'data':d, 'msg':'Added to cart !!'})

    else:
        return redirect('plogout')


def pviewcart(request):
    pemail=request.session['pemail']
    if request.method=='POST':
        
        from django.db.models import F
        
        c1=cart_p.objects.filter(pemail=pemail)
        sum=0
        for c11 in c1:
            drugstock_p.objects.filter(did = c11.did).update(stock=F('stock')+c11.count)
            sum=sum+c11.totcost
        
        return render(request, 'pay2.html',{'amt':sum, })

    else:
        c1=cart_p.objects.filter(pemail=pemail)
        return render(request, 'viewcart_p.html',{'data':c1, })



