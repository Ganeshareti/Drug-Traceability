def addstock(request):
    did=request.GET['did']
    memail=request.session["memail"]
    stock=int(request.GET['stock'])
    from django.db.models import F
    
    drug.objects.filter(did = did).update(stock=F('stock')+stock)
    d=drug.objects.filter(cemail__exact=memail)
    
    return render(request, 'viewdrug.html',{'data':d, 'msg':'Stock Updated'})

def viewstock(request):
    did=int(float(request.GET['did']))
    memail=request.session["memail"]
    d2=drug.objects.filter(did__exact=did)
    d2=d2[0].stock
    d=drug.objects.filter(cemail__exact=memail)
    
    return render(request, 'viewdrug.html',{'data':d, 'stock':d2, 'b':True})




   
